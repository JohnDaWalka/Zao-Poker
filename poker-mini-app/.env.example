# Default values for local development
# For production, update these URLs to your deployed domain
KV_REST_API_TOKEN=''
KV_REST_API_URL=''
NEXT_PUBLIC_URL='http://localhost:3000'
NEXTAUTH_URL='http://localhost:3000'

# Shared multiplayer database (required for production/serverless hosting)
TURSO_DATABASE_URL=''
TURSO_AUTH_TOKEN=''

# FastAPI Backend URL
BACKEND_URL='http://localhost:8080'

# WalletConnect (browser/Android wallet connect modal in ConnectWallet.tsx).
# Get a free project ID at https://cloud.walletconnect.com
# Optional: without it, the WalletConnect connector is simply skipped and
# Farcaster Frame / Coinbase / MetaMask / generic injected still work.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=''

# Account abstraction (email/social login -> ZeroDev smart wallet).
# Both optional and independent of everything else — without them, Farcaster
# auth and the regular wallet connectors above are completely unaffected.
#
# 1. NEXT_PUBLIC_PRIVY_APP_ID: create an app at https://dashboard.privy.io
#    Enables the "Continue with Email" button (PrivyLoginButton.tsx).
# 2. NEXT_PUBLIC_ZERODEV_BUNDLER_RPC: create a project at
#    https://dashboard.zerodev.app (pick Base as the chain), copy its
#    bundler RPC URL. Without this, logging in via Privy still gives the
#    user a regular embedded EOA wallet — it just won't be upgraded to a
#    ZeroDev smart account.
# 3. NEXT_PUBLIC_ZERODEV_PAYMASTER_RPC: same ZeroDev project's paymaster RPC
#    URL. Leave blank until you've set spending limits in the ZeroDev
#    dashboard — without it, smart accounts pay their own gas instead of
#    being sponsored. There is currently no on-chain poker action to
#    sponsor (table actions are off-chain DB writes), so there's no rush to
#    set this until that changes.
NEXT_PUBLIC_PRIVY_APP_ID=''
NEXT_PUBLIC_ZERODEV_BUNDLER_RPC=''
NEXT_PUBLIC_ZERODEV_PAYMASTER_RPC=''
